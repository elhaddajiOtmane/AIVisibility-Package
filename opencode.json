{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "subagent",
      "model": "google/gemini-3.1-pro",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "subagent",
      "model": "gemini/gemini-3.1-pro",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "orchestrator": {
      "permissions": {
        "task": {
          "allow": ["build", "plan"]
        }
      }
    }
  }
}
