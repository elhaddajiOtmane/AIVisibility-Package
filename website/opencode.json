{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-20250514",
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "orchestrator": {
      "permissions": {
        "task": {
          "allow": ["build", "plan"]
        }
      }
    }
  }
}
